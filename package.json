{
  "name": "codedynasty",
  "version": "1.0.0",
  "description": "",
  "main": "server.js",
  "scripts": {
    "test": "jest",
    "test:smoke": "node -e \"console.log('smoke ok')\"",
    "test:coverage": "jest --coverage --coverageThreshold='{\"global\":{\"lines\":60,\"statements\":60,\"functions\":20,\"branches\":20}}'",
    "start": "node server.js",
    "build": "mkdir -p build && cp src/server.js src/index.html package.json build/",
    "lint": "echo No lint configured"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "dotenv": "^17.2.3",
    "express": "^5.1.0"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "jest-junit": "^17.0.0",
    "supertest": "^7.1.4"
  },
  "jest": {
    "coverageProvider": "v8",
    "coverageThreshold": {
      "global": {
        "lines": 70,
        "functions": 70,
        "branches": 70
      }
    },
    "reporters": [
      "default",
      [
        "jest-junit",
        {
          "outputDirectory": "build",
          "outputName": "test-report.xml"
        }
      ]
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pearlvee/aws-devops-class01.git"
  },
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/pearlvee/aws-devops-class01/issues"
  },
  "homepage": "https://github.com/pearlvee/aws-devops-class01#readme"
}